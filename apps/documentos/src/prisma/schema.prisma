// Prisma Schema para Microservicio Documentos
// "Simplicidad es la sofisticación definitiva"

generator client {
  provider        = "prisma-client-js"
  output          = "../../node_modules/.prisma/documentos"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["views"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DOCUMENTOS_DATABASE_URL")
  directUrl = env("DOCUMENTOS_DATABASE_URL")
}

// =================================
// ENUMS - Estados Simples y Claros
// =================================

enum EntityType {
  DADOR
  EMPRESA_TRANSPORTISTA
  CHOFER
  CAMION
  ACOPLADO
}

enum DocumentStatus {
  PENDIENTE             // Subido, esperando clasificación/validación
  VALIDANDO             // En proceso de validación IA (legacy, compat)
  CLASIFICANDO          // En proceso de clasificación IA
  PENDIENTE_APROBACION  // Clasificado, esperando aprobación humana
  APROBADO              // Validado y aprobado
  RECHAZADO             // Validación falló
  VENCIDO               // Documento expiró
  DEPRECADO             // Reemplazado por una versión más nueva
}

// Notificaciones
enum NotificationType {
  aviso
  alerta
  alarma
  faltante
}

enum NotificationAudience {
  CHOFER
  DADOR
}

// =================================
// MODELOS ESENCIALES (ampliados)
// =================================

// Plantillas globales configurables por superadmin
model DocumentTemplate {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  entityType  EntityType @map("entity_type")
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relaciones
  clientRequirements ClienteDocumentRequirement[] @relation("TemplateToClienteRequirement")
  documents    Document[]

  @@index([entityType, active])
  @@map("document_templates")
}

// Eliminados modelos dependientes de 'empresa'

// Documentos subidos por usuarios
model Document {
  id            Int            @id @default(autoincrement())
  templateId    Int            @map("template_id")
  entityType    EntityType     @map("entity_type")
  entityId      Int            @map("entity_id")
  dadorCargaId  Int            @map("dador_carga_id")
  tenantEmpresaId Int          @map("tenant_empresa_id")
  
  // Información del archivo
  fileName      String         @map("file_name") @db.VarChar(255)
  filePath      String         @map("file_path") @db.VarChar(500)
  fileSize      Int            @map("file_size")
  mimeType      String         @map("mime_type") @db.VarChar(100)
  
  // Nombres de archivo (original y estandarizado)
  originalFileName     String?  @map("original_file_name") @db.VarChar(255)
  standardizedFileName String?  @map("standardized_file_name") @db.VarChar(255)
  
  // Estado y validación
  status        DocumentStatus @default(PENDIENTE)
  validationData Json?         @map("validation_data")
  expiresAt     DateTime?      @map("expires_at")
  
  // Archivado (para documentos que ya no aplican)
  archived      Boolean        @default(false)
  archivedAt    DateTime?      @map("archived_at")
  archivedBy    Int?           @map("archived_by")
  archiveReason String?        @map("archive_reason") @db.VarChar(50)
  
  // Rechazo
  rejectedAt      DateTime?    @map("rejected_at")
  rejectedBy      Int?         @map("rejected_by")
  rejectionReason String?      @map("rejection_reason") @db.Text
  rejectionCount  Int          @default(0) @map("rejection_count")
  
  // Revisión
  reviewedAt      DateTime?    @map("reviewed_at")
  reviewedBy      Int?         @map("reviewed_by")
  reviewNotes     String?      @map("review_notes") @db.Text
  
  // Timestamps
  uploadedAt    DateTime       @default(now()) @map("uploaded_at")
  validatedAt   DateTime?      @map("validated_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relaciones
  template    DocumentTemplate     @relation(fields: [templateId], references: [id])

  classification DocumentClassification?

  @@index([tenantEmpresaId, dadorCargaId, entityType, entityId])
  @@index([status, expiresAt])
  @@index([templateId])
  @@index([archived])
  @@map("documents")
}

// =================================
// CLIENTES y REQUISITOS POR CLIENTE
// =================================

// =================================
// MAESTROS: CHOFERES, CAMIONES, ACOPLADOS (asociados a DADOR DE CARGA)
// =================================

model Chofer {
  id           Int      @id @default(autoincrement())
  dadorCargaId Int      @map("dador_carga_id")
  tenantEmpresaId Int   @map("tenant_empresa_id")
  empresaTransportistaId Int?     @map("empresa_transportista_id")
  dni          String   @db.VarChar(32)
  dniNorm      String   @map("dni_norm") @db.VarChar(32)
  nombre       String?  @db.VarChar(120)
  apellido     String?  @db.VarChar(120)
  phones       String[] @default([])
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dador DadorCarga @relation(fields: [dadorCargaId], references: [id])
  empresaTransportista EmpresaTransportista? @relation(fields: [empresaTransportistaId], references: [id])

  @@unique([tenantEmpresaId, dadorCargaId, dniNorm])
  @@index([tenantEmpresaId, dadorCargaId])
  @@map("choferes")
}

model Camion {
  id          Int      @id @default(autoincrement())
  dadorCargaId Int     @map("dador_carga_id")
  tenantEmpresaId Int  @map("tenant_empresa_id")
  empresaTransportistaId Int?     @map("empresa_transportista_id")
  patente     String   @db.VarChar(32)
  patenteNorm String   @map("patente_norm") @db.VarChar(32)
  marca       String?  @db.VarChar(120)
  modelo      String?  @db.VarChar(120)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dador DadorCarga @relation(fields: [dadorCargaId], references: [id])
  empresaTransportista EmpresaTransportista? @relation(fields: [empresaTransportistaId], references: [id])

  @@unique([tenantEmpresaId, dadorCargaId, patenteNorm])
  @@index([tenantEmpresaId, dadorCargaId])
  @@map("camiones")
}

model Acoplado {
  id          Int      @id @default(autoincrement())
  dadorCargaId Int     @map("dador_carga_id")
  tenantEmpresaId Int  @map("tenant_empresa_id")
  empresaTransportistaId Int?     @map("empresa_transportista_id")
  patente     String   @db.VarChar(32)
  patenteNorm String   @map("patente_norm") @db.VarChar(32)
  tipo        String?  @db.VarChar(120)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dador DadorCarga @relation(fields: [dadorCargaId], references: [id])
  empresaTransportista EmpresaTransportista? @relation(fields: [empresaTransportistaId], references: [id])

  @@unique([tenantEmpresaId, dadorCargaId, patenteNorm])
  @@index([tenantEmpresaId, dadorCargaId])
  @@map("acoplados")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  tenantEmpresaId Int  @map("tenant_empresa_id")
  razonSocial String   @map("razon_social") @db.VarChar(200)
  cuit        String   @db.VarChar(20)
  activo      Boolean  @default(true)
  notas       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requisitos ClienteDocumentRequirement[]
  equipos    EquipoCliente[]

  @@unique([tenantEmpresaId, cuit])
  @@index([tenantEmpresaId])
  @@map("clientes")
}

// =================================
// DADOR DE CARGA (empresa externa que provee transportistas)
// =================================

model DadorCarga {
  id          Int      @id @default(autoincrement())
  tenantEmpresaId Int  @map("tenant_empresa_id")
  razonSocial String   @map("razon_social") @db.VarChar(200)
  cuit        String   @db.VarChar(20)
  phones      String[] @default([])
  notifyDriverEnabled Boolean @default(true) @map("notify_driver_enabled")
  notifyDadorEnabled  Boolean @default(true) @map("notify_dador_enabled")
  activo      Boolean  @default(true)
  notas       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  equipos Equipo[]
  choferes Chofer[]
  camiones Camion[]
  acoplados Acoplado[]
  empresasTransportistas EmpresaTransportista[]

  @@unique([tenantEmpresaId, cuit])
  @@index([tenantEmpresaId])
  @@map("dadores_carga")
}
model ClienteDocumentRequirement {
  id               Int        @id @default(autoincrement())
  tenantEmpresaId  Int        @map("tenant_empresa_id")
  clienteId        Int        @map("cliente_id")
  templateId       Int        @map("template_id")
  entityType       EntityType @map("entity_type")
  obligatorio      Boolean    @default(true)
  diasAnticipacion Int        @default(0) @map("dias_anticipacion")
  visibleChofer    Boolean    @default(true) @map("visible_chofer")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  cliente  Cliente          @relation(fields: [clienteId], references: [id])
  template DocumentTemplate @relation("TemplateToClienteRequirement", fields: [templateId], references: [id])

  @@unique([tenantEmpresaId, clienteId, templateId, entityType])
  @@index([tenantEmpresaId, clienteId, entityType])
  @@map("cliente_document_requirement")
}

// =================================
// EQUIPOS y RELACIÓN CON CLIENTES
// =================================

enum EquipoEstado {
  activa
  finalizada
}

model Equipo {
  id                Int          @id @default(autoincrement())
  driverId          Int          @map("driver_id")
  truckId           Int          @map("truck_id")
  trailerId         Int?         @map("trailer_id")
  dadorCargaId      Int          @map("dador_carga_id")
  tenantEmpresaId   Int          @map("tenant_empresa_id")
  empresaTransportistaId Int?     @map("empresa_transportista_id")
  driverDniNorm     String       @map("driver_dni_norm") @db.VarChar(32)
  truckPlateNorm    String       @map("truck_plate_norm") @db.VarChar(32)
  trailerPlateNorm  String?      @map("trailer_plate_norm") @db.VarChar(32)
  validFrom         DateTime     @map("valid_from")
  validTo           DateTime?    @map("valid_to")
  estado            EquipoEstado @default(activa)
  activo            Boolean      @default(true)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  clientes EquipoCliente[]
  history  EquipoHistory[]
  auditLogs EquipoAuditLog[]
  dador    DadorCarga?          @relation(fields: [dadorCargaId], references: [id])
  empresaTransportista EmpresaTransportista? @relation(fields: [empresaTransportistaId], references: [id])

  @@index([tenantEmpresaId, dadorCargaId, driverDniNorm])
  @@index([tenantEmpresaId, dadorCargaId, truckPlateNorm])
  @@index([tenantEmpresaId, dadorCargaId, trailerPlateNorm])
  @@index([tenantEmpresaId, dadorCargaId])
  @@index([validFrom, validTo])
  @@unique([tenantEmpresaId, dadorCargaId, driverDniNorm, truckPlateNorm, trailerPlateNorm, validFrom])
  @@map("equipo")
}

model EquipoCliente {
  equipoId       Int       @map("equipo_id")
  clienteId      Int       @map("cliente_id")
  asignadoDesde  DateTime  @map("asignado_desde")
  asignadoHasta  DateTime? @map("asignado_hasta")

  equipo  Equipo  @relation(fields: [equipoId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@id([equipoId, clienteId, asignadoDesde])
  @@index([clienteId, equipoId])
  @@map("equipo_cliente")
}

// Historial mínimo de movimientos de componentes de equipos
model EquipoHistory {
  id               Int      @id @default(autoincrement())
  equipoId         Int      @map("equipo_id")
  action           String   @db.VarChar(32) // attach|detach|create|forcemove|close|reopen
  component        String   @db.VarChar(16) // driver|truck|trailer|empresa
  originEquipoId   Int?     @map("origin_equipo_id")
  payload          Json?
  createdAt        DateTime @default(now()) @map("created_at")

  equipo  Equipo  @relation(fields: [equipoId], references: [id])

  @@index([equipoId, createdAt])
  @@map("equipo_history")
}

// =================================
// CONFIGURACIÓN DEL SISTEMA
// =================================

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String?  @db.Text
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// Registro de notificaciones enviadas (deduplicación y auditoría)
model NotificationLog {
  id               Int                   @id @default(autoincrement())
  tenantEmpresaId  Int                   @map("tenant_empresa_id")
  dadorCargaId     Int?                  @map("dador_carga_id")
  documentId       Int?                  @map("document_id")
  equipoId         Int?                  @map("equipo_id")
  type             NotificationType
  audience         NotificationAudience
  target           String                @db.VarChar(64)
  templateKey      String                @map("template_key") @db.VarChar(64)
  payload          Json?
  status           String                @db.VarChar(16)
  error            String?               @db.Text
  sentAt           DateTime              @default(now()) @map("sent_at")

  @@index([documentId, type, audience])
  @@index([equipoId, type, audience])
  @@map("notification_log")
}

// =================================
// VISTA MATERIALIZADA PARA PERFORMANCE
// =================================

// Esta vista se actualizará via triggers para performance óptima
// Materialized view para performance del dashboard
// Se crea manualmente en migración SQL

// =================================
// EMPRESA TRANSPORTISTA (nueva entidad intermedia)
// =================================

model EmpresaTransportista {
  id              Int      @id @default(autoincrement())
  dadorCargaId    Int      @map("dador_carga_id")
  tenantEmpresaId Int      @map("tenant_empresa_id")
  razonSocial     String   @map("razon_social") @db.VarChar(200)
  cuit            String   @db.VarChar(20)
  activo          Boolean  @default(true)
  notas           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relaciones
  dador     DadorCarga @relation(fields: [dadorCargaId], references: [id])
  choferes  Chofer[]
  camiones  Camion[]
  acoplados Acoplado[]
  equipos   Equipo[]

  @@unique([tenantEmpresaId, dadorCargaId, cuit])
  @@index([tenantEmpresaId, dadorCargaId])
  @@map("empresas_transportistas")
}

// =================================
// CLASIFICACIÓN DE DOCUMENTOS (para aprobación manual)
// =================================

model DocumentClassification {
  id                    Int         @id @default(autoincrement())
  documentId            Int         @unique @map("document_id")
  detectedEntityType    EntityType? @map("detected_entity_type")
  detectedEntityId      String?     @map("detected_entity_id") @db.VarChar(100)
  detectedExpiration    DateTime?   @map("detected_expiration")
  detectedDocumentType  String?     @map("detected_document_type") @db.VarChar(100)
  confidence            Float       @default(0.0)
  aiResponse            Json?       @map("ai_response")
  reviewedAt            DateTime?   @map("reviewed_at")
  reviewedBy            Int?        @map("reviewed_by")
  reviewNotes           String?     @map("review_notes") @db.Text
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  
  // Validación de documento (Control IA)
  documentoEsValido     Boolean?    @map("documento_es_valido")
  motivoInvalidez       String?     @map("motivo_invalidez") @db.Text
  datosExtraidos        Json?       @map("datos_extraidos")
  disparidades          Json?       @map("disparidades")
  tieneDisparidades     Boolean     @default(false) @map("tiene_disparidades")
  vencimientoDetectado  DateTime?   @map("vencimiento_detectado")
  vencimientoOrigen     String?     @map("vencimiento_origen") @db.VarChar(20)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([detectedEntityType, confidence])
  @@index([reviewedAt])
  @@index([tieneDisparidades])
  @@map("document_classifications")
}

// =================================
// AUDITORÍA
// =================================
model AuditLog {
  id               Int       @id @default(autoincrement())
  tenantEmpresaId  Int?      @map("tenant_empresa_id")
  accion           String    @db.VarChar(150)
  detalles         Json?
  userId           Int?      @map("user_id")
  userEmail        String?   @map("user_email") @db.VarChar(150)
  userRole         String?   @map("user_role") @db.VarChar(50)
  statusCode       Int       @map("status_code")
  method           String    @db.VarChar(10)
  path             String    @db.VarChar(500)
  entityType       String?   @map("entity_type") @db.VarChar(50)
  entityId         Int?      @map("entity_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([tenantEmpresaId, createdAt])
  @@index([userId, createdAt])
  @@index([accion, createdAt])
  @@map("audit_logs")
}

// =================================
// AUDITORÍA ESPECÍFICA DE EQUIPOS
// =================================
model EquipoAuditLog {
  id              Int      @id @default(autoincrement())
  equipoId        Int      @map("equipo_id")
  usuarioId       Int      @map("usuario_id")
  accion          String   @db.VarChar(32) // CREAR, EDITAR, ELIMINAR, TRANSFERIR
  campoModificado String?  @map("campo_modificado") @db.VarChar(50)
  valorAnterior   Json?    @map("valor_anterior")
  valorNuevo      Json?    @map("valor_nuevo")
  motivo          String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  equipo Equipo @relation(fields: [equipoId], references: [id])

  @@index([equipoId])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("equipo_audit_logs")
}

// =================================
// DATOS EXTRAÍDOS POR IA (solo visible para admins)
// =================================

model EntityExtractedData {
  id              Int        @id @default(autoincrement())
  tenantEmpresaId Int        @map("tenant_empresa_id")
  dadorCargaId    Int        @map("dador_carga_id")
  entityType      EntityType @map("entity_type")
  entityId        Int        @map("entity_id")
  
  // Datos extraídos (JSON flexible)
  datosExtraidos  Json       @map("datos_extraidos")
  
  // Metadatos de última extracción
  ultimaExtraccionAt    DateTime   @map("ultima_extraccion_at")
  ultimoDocumentoId     Int?       @map("ultimo_documento_id")
  ultimoDocumentoTipo   String?    @map("ultimo_documento_tipo") @db.VarChar(100)
  confianzaPromedio     Float      @default(0.0) @map("confianza_promedio")
  
  // Campos consolidados CHOFER
  cuil              String?  @db.VarChar(20)
  fechaNacimiento   DateTime? @map("fecha_nacimiento")
  nacionalidad      String?  @db.VarChar(50)
  numeroLicencia    String?  @map("numero_licencia") @db.VarChar(50)
  clasesLicencia    String[] @default([]) @map("clases_licencia")
  vencimientoLicencia DateTime? @map("vencimiento_licencia")
  
  // Campos consolidados CAMION/ACOPLADO
  anioFabricacion   Int?     @map("anio_fabricacion")
  numeroMotor       String?  @map("numero_motor") @db.VarChar(50)
  numeroChasis      String?  @map("numero_chasis") @db.VarChar(50)
  titular           String?  @db.VarChar(200)
  titularDni        String?  @map("titular_dni") @db.VarChar(20)
  
  // Campos consolidados EMPRESA_TRANSPORTISTA
  condicionIva      String?  @map("condicion_iva") @db.VarChar(50)
  domicilioFiscal   Json?    @map("domicilio_fiscal")
  actividadPrincipal Json?   @map("actividad_principal")
  cantidadEmpleados Int?     @map("cantidad_empleados")
  artNombre         String?  @map("art_nombre") @db.VarChar(100)
  artPoliza         String?  @map("art_poliza") @db.VarChar(50)
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([tenantEmpresaId, entityType, entityId])
  @@index([tenantEmpresaId, dadorCargaId, entityType])
  @@index([entityType, entityId])
  @@map("entity_extracted_data")
}

model EntityExtractionLog {
  id              Int        @id @default(autoincrement())
  tenantEmpresaId Int        @map("tenant_empresa_id")
  entityType      EntityType @map("entity_type")
  entityId        Int        @map("entity_id")
  documentId      Int        @map("document_id")
  templateName    String     @map("template_name") @db.VarChar(100)
  
  // Resultado de la extracción
  datosExtraidos  Json       @map("datos_extraidos")
  disparidades    Json?      @map("disparidades")
  esValido        Boolean    @map("es_valido")
  confianza       Float      @default(0.0)
  
  // Quién solicitó
  solicitadoPor   Int?       @map("solicitado_por")
  esRechequeo     Boolean    @default(false) @map("es_rechequeo")
  
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([tenantEmpresaId, entityType, entityId])
  @@index([documentId])
  @@index([createdAt])
  @@map("entity_extraction_log")
}