{
  "name": "documentos",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --exit-child --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "rm -rf dist/__tests__",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "docs:openapi": "npx @redocly/cli bundle openapi.yaml -o openapi.json && npx @redocly/cli lint openapi.yaml",
    "docs:html": "npx @redocly/cli build-docs openapi.yaml -o openapi.html",
    "templates:reset": "dotenv -e ../../.env -- ts-node src/scripts/resetTemplates.ts"
  },
  "keywords": [
    "documentos",
    "transportistas",
    "validacion",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "description": "Microservicio elegante para gestión documental de transportistas",
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.14",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jest": "^30.0.4",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.1"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "archiver": "^6.0.1",
    "axios": "^1.11.0",
    "bullmq": "^5.56.4",
    "clamscan": "^2.1.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.12.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.16.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yaml": "^2.4.5",
    "zod": "^3.24.1"
  }
}
