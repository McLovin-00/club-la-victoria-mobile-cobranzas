{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": false
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/config/**/*.ts",
    "src/controllers/empresa.controller.ts",
    "src/controllers/auth.controller.ts",
    "src/controllers/dashboard.controller.ts",
    "src/controllers/platformAuth.controller.ts",
    "src/controllers/user.controller.ts",
    "src/middlewares/**/*.ts",
    "src/routes/empresa.routes.ts",
    "src/routes/auth.routes.ts",
    "src/routes/dashboard.routes.ts",
    "src/routes/health.routes.ts",
    "src/routes/metrics.routes.ts",
    "src/routes/openapi.routes.ts",
    "src/routes/config.routes.ts",
    "src/routes/service.routes.ts",
    "src/routes/calidad-proxy.routes.ts",
    "src/routes/platformAuth.routes.ts",
    "src/routes/user.routes.ts",
    "src/routes/endUser.routes.ts",
    "src/routes/instance.routes.ts",
    "src/routes/permiso.routes.ts",
    "src/routes/notifications.routes.ts",
    "src/routes/evolution.routes.ts",
    "src/routes/docs.routes.ts",
    "src/services/auth.service.ts",
    "src/services/platformAuth.service.ts",
    "src/services/endUser.service.ts",
    "src/services/empresa.service.ts",
    "src/services/base.service.ts",
    "src/services/prisma.service.ts",
    "src/services/user.service.ts",
    "src/services/service.service.ts",
    "src/services/database-initialization.service.ts",
    "src/services/instance.service.ts",
    "src/seed/index.ts",
    "src/controllers/service.controller.ts",
    "src/controllers/instance.controller.ts",
    "src/types/express.d.ts",
    "src/types/auth.types.ts",
    "src/interfaces/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "src/scripts/**"
  ]
}
