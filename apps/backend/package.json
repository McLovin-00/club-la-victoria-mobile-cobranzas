{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend para el sistema de gestión de empresas",
  "main": "dist/server.js",
  "scripts": {
    "predev": "ts-node src/scripts/setup-database.ts",
    "dev": "dotenv -e ../../.env --override -- ts-node-dev --respawn --transpile-only src/server.ts",
    "split:sync": "ts-node src/scripts/migrate-user-split.ts",
    "build": "tsc -p tsconfig.clean.json",
    "start": "node dist/src/server.js",
    "test": "jest --config ./jest.config.js",
    "test:coverage": "jest --config ./jest.config.js --coverage",
    "test:watch": "jest --watch",
    "lint": "node --enable-source-maps ../../node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node --enable-source-maps ../../node_modules/eslint/bin/eslint.js . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "db:init": "ts-node scripts/setup-database.ts",
    "db:setup": "ts-node scripts/setup-database.ts",
    "db:setup:force": "ts-node scripts/setup-database.ts --force",
    "db:setup:skip-seeds": "ts-node scripts/setup-database.ts --skip-seeds",
    "db:setup:verbose": "ts-node scripts/setup-database.ts --verbose",
    "db:reset": "ts-node scripts/reset-database.ts",
    "db:reset:confirm": "ts-node scripts/reset-database.ts --confirm",
    "db:reset:force": "ts-node scripts/reset-database.ts --force --confirm",
    "db:fresh": "ts-node scripts/reset-database.ts --confirm && ts-node scripts/setup-database.ts",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:reset": "npx prisma migrate reset",
    "migrate:status": "npx prisma migrate status",
    "migrate:user-split": "ts-node src/scripts/migrate-user-split.ts",
    "baseline:user-split": "ts-node src/scripts/baseline-after-split.ts",
    "seed": "ts-node -e \"require('./src/seed').runSeeds()\"",
    "seed:force": "ts-node -e \"require('./src/seed').runSeeds()\" --force",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:push": "npx prisma db push",
    "db:pull": "npx prisma db pull",
    "db:validate": "npx prisma validate",
    "db:backup": "pg_dump $DATABASE_URL > backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:restore": "echo 'Specify backup file: npm run db:restore -- backup_file.sql'",
    "postinstall": "npm run db:generate",
    "prestart": "npm run build",
    "dev:setup": "npm run db:generate",
    "dev:check-database": "ts-node scripts/dev-database-check.ts",
    "dev:optimized": "SKIP_PRISMA_INIT=true nodemon src/server.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "@types/multer": "^2.0.0",
    "@types/winston": "^2.4.4",
    "@workspace/types": "file:../../packages/types",
    "@workspace/utils": "file:../../packages/utils",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.4",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.10.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^24.0.14",
    "@types/pg": "^8.10.2",
    "bcryptjs": "^3.0.2",
    "dotenv-cli": "^8.0.0",
    "jest": "^30.0.4",
    "nodemon": "^3.0.1",
    "prisma": "^6.12.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1"
  },
  "keywords": [
    "backend",
    "api",
    "typescript",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "Sistema de Gestión",
  "license": "MIT"
}
