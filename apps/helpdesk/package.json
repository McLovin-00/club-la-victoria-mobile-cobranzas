{
  "name": "helpdesk",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --exit-child --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "pretest": "node -e \"require('node:fs').rmSync('dist/__tests__', { recursive: true, force: true })\"",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "seed:dev-tickets": "dotenv -e ../../.env -- npx tsx scripts/seed-dev-tickets.ts"
  },
  "keywords": [
    "helpdesk",
    "tickets",
    "telegram",
    "soporte"
  ],
  "author": "Microsyst Team",
  "license": "MIT",
  "description": "Microservicio de Mesa de Ayuda con integración Telegram",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.14",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "globals": "^16.0.0",
    "jest": "^30.0.4",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@prisma/client": "^6.12.0",
    "bullmq": "^5.56.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "grammy": "^1.36.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "prisma": "^6.12.0",
    "socket.io": "^4.8.1",
    "winston": "^3.16.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.24.1"
  }
}
