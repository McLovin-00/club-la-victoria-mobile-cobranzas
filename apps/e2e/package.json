{
  "name": "e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Tests E2E con Playwright para el monorepo BCA",
  "type": "commonjs",
  "scripts": {
    "pw:install": "playwright install",
    "pw:test": "playwright test",
    "pw:ui": "playwright test --ui",
    "pw:report": "playwright show-report",
    "pw:codegen": "playwright codegen",
    "pw:setup:cliente": "playwright test tests/setup/cliente.setup.ts --project=setup-cliente --workers=1",
    "pw:setup:chofer": "playwright test tests/setup/chofer.setup.ts --project=setup-chofer --workers=1",
    "pw:setup:transportista": "playwright test tests/setup/transportista.setup.ts --project=setup-transportista --workers=1",
    "pw:setup:dador": "playwright test tests/setup/dadorDeCarga.setup.ts --project=setup-dadorDeCarga --workers=1",
    "pw:setup:admin": "playwright test tests/setup/adminInterno.setup.ts --project=setup-adminInterno --workers=1",
    "pw:setup:all": "npm run pw:setup:cliente && npm run pw:setup:chofer && npm run pw:setup:transportista && npm run pw:setup:dador && npm run pw:setup:admin",
    "pw:smoke:cliente": "playwright test tests/auth/cliente.auth.spec.ts --project=smoke-cliente --workers=1",
    "pw:smoke:chofer": "playwright test tests/auth/chofer.auth.spec.ts --project=smoke-chofer --workers=1",
    "pw:smoke:transportista": "playwright test tests/auth/transportista.auth.spec.ts --project=smoke-transportista --workers=1",
    "pw:smoke:dador": "playwright test tests/auth/dador.auth.spec.ts --project=smoke-dador --workers=1",
    "pw:smoke:admin": "playwright test tests/auth/adminInterno.auth.spec.ts --project=smoke-admin --workers=1",
    "test:portal": "node scripts/run-portal-tests.js",
    "test:cliente": "node scripts/run-portal-tests.js cliente",
    "test:chofer": "node scripts/run-portal-tests.js chofer",
    "test:transportista": "node scripts/run-portal-tests.js transportista",
    "test:dador": "node scripts/run-portal-tests.js dadorDeCarga",
    "test:admin": "node scripts/run-portal-tests.js adminInterno",
    "test:all": "node scripts/run-portal-tests.js all",
    "test:unit": "jest --coverage",
    "test:unit:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "sonar": "powershell -ExecutionPolicy Bypass -File scripts/sonar-analyze.ps1",
    "checklists:generate": "node scripts/generate-checklists.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/jest": "^30.0.0",
    "dotenv": "^16.6.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
