{
  "name": "remitos",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --exit-child --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --ext .ts --fix",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma"
  },
  "keywords": [
    "remitos",
    "transportistas",
    "ocr",
    "flowise"
  ],
  "description": "Microservicio para gestión de remitos con análisis IA",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.14",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "axios": "^1.11.0",
    "bullmq": "^5.56.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.12.0",
    "sharp": "^0.33.5",
    "winston": "^3.16.0",
    "zod": "^3.24.1"
  }
}
