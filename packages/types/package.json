{
  "name": "@workspace/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for the empresa management monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "keywords": [
    "typescript",
    "types",
    "shared",
    "monorepo"
  ],
  "author": "Empresa Management Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.18.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
} 