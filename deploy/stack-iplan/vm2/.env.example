# =============================================================================
# VM2 - Data Layer (10.8.10.121)
# =============================================================================
# Copiar a .env y completar con valores reales.
# Los servicios se bindean solo a VM2_IP (no 0.0.0.0).
# =============================================================================

# --- Red ---
VM2_IP=10.8.10.121

# --- PostgreSQL ---
# Password del superusuario (evo). Usar solo para administracion.
POSTGRES_PASSWORD=<cambiar-password-seguro>

# --- Redis ---
REDIS_PASSWORD=<cambiar-password-seguro>

# --- MinIO ---
MINIO_ROOT_USER=<cambiar-root-user>
MINIO_ROOT_PASSWORD=<cambiar-root-password>

# --- Passwords para el script de inicializacion (01-users.sql) ---
# Estos se usan UNA VEZ al crear el volumen de PostgreSQL.
# Despues del init, cambiarlos requiere ALTER USER en psql.
# DB_APP_PASSWORD:      usado por backend, documentos, remitos
# DB_FLOWISE_PASSWORD:  usado por flowise (solo schema flowise)
# DB_READONLY_PASSWORD: usado por monitoring/reporting (solo SELECT)
# REPL_PASSWORD:        usado por la replica en VM3
#
# Nota: psql -v ON_ERROR_STOP=1 interpola :'VAR' desde env.
# Revisar que el script 01-users.sql use la sintaxis correcta
# para la version de PostgreSQL.
