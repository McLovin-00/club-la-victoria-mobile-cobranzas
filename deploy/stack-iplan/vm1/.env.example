# =============================================================================
# VM1 - Application + Edge (10.8.10.120)
# =============================================================================
# Copiar a .env y completar con valores reales antes de levantar.
# NUNCA versionar el .env con valores reales en Git.
# =============================================================================

# --- Red ---
VM2_IP=10.8.10.121

# --- Ruta al monorepo (para builds) ---
MONOREPO_PATH=/home/administrador/monorepo-bca

# --- Frontend ---
APP_TITLE=BCA Group

# --- CORS / URLs publicas ---
# Fase 1 (testing paralelo):
FRONTEND_URLS=https://grupobca.microsyst.com.ar,https://bca-group.microsyst.com.ar
CORS_ORIGIN=https://grupobca.microsyst.com.ar,https://bca-group.microsyst.com.ar

# --- Base de datos (usuario app, compartido por backend/documentos/remitos) ---
DB_APP_PASSWORD=<cambiar-password-seguro>

# --- Redis ---
REDIS_PASSWORD=<cambiar-password-seguro>

# --- MinIO (acceso de aplicacion, no root) ---
MINIO_ACCESS_KEY=<cambiar-access-key>
MINIO_SECRET_KEY=<cambiar-secret-key>

# URL publica para presigned URLs (via proxy /storage en Nginx)
# Fase 1: https://grupobca.microsyst.com.ar/storage
# Fase 2: https://bca-group.microsyst.com.ar/storage
MINIO_PUBLIC_BASE_URL=https://grupobca.microsyst.com.ar/storage

# --- Flowise ---
FLOWISE_PASSWORD=<cambiar-password-seguro>
FLOWISE_SECRET_KEY=<cambiar-secret-key>
DB_FLOWISE_PASSWORD=<cambiar-password-seguro>
FLOWISE_DOCS_FLOW_ID=<flow-id-de-flowise>
FLOWISE_REMITOS_FLOW_ID=<flow-id-de-flowise>

# --- JWT ---
# Las claves se montan desde ./keys/jwt_private.pem y ./keys/jwt_public.pem
# Generarlas con:
#   openssl genpkey -algorithm RSA -out keys/jwt_private.pem -pkeyopt rsa_keygen_bits:4096
#   openssl rsa -in keys/jwt_private.pem -pubout -out keys/jwt_public.pem
