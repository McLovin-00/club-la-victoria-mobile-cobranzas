# ===========================================
# CONFIGURACIÓN DEL MOBILE APP - Club La Victoria Cobranzas
# ===========================================
# Copia este archivo a .env y configura los valores según tu entorno

# URL de la API del backend
# En desarrollo local con Expo Go, puedes dejarlo vacío para usar el fallback automático
# Para dispositivos físicos en la red, usa la IP de tu máquina (ej: http://192.168.1.X:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
