# =================================
# EMPRESA MANAGEMENT SYSTEM - ENV VARS (EXAMPLE)
# Copiar como .env y ajustar valores por entorno
# Nunca commitear secretos reales
# =================================

# Environment
NODE_ENV=development
PORT=4800

# User Management Configuration (split users siempre habilitado en código)

# Database Configuration
DB_NAME=monorepo-bca
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_ADMIN_DATABASE=postgres
DB_SCHEMA=platform
DB_CONNECTION_TIMEOUT=10000
DB_COMMAND_TIMEOUT=30000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monorepo-bca?schema=platform

# JWT Configuration (usar RS256 en prod)
JWT_SECRET=change-me-in-non-prod
JWT_EXPIRES_IN=7d

# Frontend Configuration
VITE_API_URL=http://localhost:4800
VITE_API_BASE_URL=http://localhost:4800
VITE_DOCUMENTOS_API_URL=http://localhost:4802
VITE_APP_TITLE=Empresa Management System

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8550
FRONTEND_URLS=http://localhost:8550

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
ENABLE_DATABASE_LOGGING=true
ENABLE_QUERY_LOGGING=false

# Port Configuration
BACKEND_PORT=4800
FRONTEND_PORT=8550
# Eliminado: GATEWAY_PORT
NGINX_PORT=80
NGINX_HTTPS_PORT=443
NGINX_DEV_PORT=8080

# Development Tools
ADMINER_PORT=8080
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
REDIS_PORT=6379
BACKEND_DEBUG_PORT=9229

# Security Configuration
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:8550
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Email Configuration (for development)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@empresa.com

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session Configuration
SESSION_SECRET=change-me-in-non-prod
SESSION_NAME=empresa_session
SESSION_MAX_AGE=86400000

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Docker Resources
POSTGRES_MAX_CONNECTIONS=100
BACKEND_MEMORY_LIMIT=1g
FRONTEND_MEMORY_LIMIT=256m
NGINX_MEMORY_LIMIT=256m

# Development Settings
CHOKIDAR_USEPOLLING=true
FAST_REFRESH=true
GENERATE_SOURCEMAP=true

# Production Settings (uncomment for production)
# NODE_ENV=production
# LOG_LEVEL=error
# BCRYPT_ROUNDS=15
# GENERATE_SOURCEMAP=false

# SSL Configuration (for production)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CA_PATH=/path/to/ca.pem

# Backup Configuration
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=7
# BACKUP_S3_BUCKET=empresa-backups
# BACKUP_S3_REGION=us-east-1

# Monitoring Configuration
# MONITORING_ENABLED=true
# METRICS_PORT=9090
# TRACES_ENDPOINT=http://jaeger:14268/api/traces
ENABLE_FRONTEND=true
ENABLE_BACKEND=true
ENABLE_DOCUMENTOS=true

## Eliminados: Prisma (chat-processor/gateway)

## Eliminado: Chat Processor Configuration

# ==========================================
# NOTA: Configuraciones por instancia (Flowise, Evolution API, etc.)
# se configuran desde el frontend y se almacenan en la base de datos
# en chatProcessorInstance.configuration - NO van aquí
# ==========================================

# Redis URL (formato completo para chat-processor)
REDIS_URL=redis://localhost:6379

# =================================
# MICROSERVICIO DOCUMENTOS
# =================================
DOCUMENTOS_PORT=4802
DOCUMENTOS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monorepo-bca?schema=documentos

# =================================
# MICROSERVICIO HELPDESK (Mesa de Ayuda)
# =================================
HELPDESK_PORT=4803
HELPDESK_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monorepo-bca?schema=helpdesk
ENABLE_HELPDESK=true

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Helpdesk Configuration
AUTO_CLOSE_HOURS=72
REOPEN_ALLOWED_HOURS=72

# MinIO Bucket Prefix for Helpdesk attachments
# MINIO_BUCKET_PREFIX=helpdesk

# Helpdesk WebSocket URL
VITE_HELPDESK_WS_URL=http://localhost:4803

# JWT RS256 para Documentos (usar una de las dos opciones)
# Opción A: clave pública inline (escapar \n)
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkq...\n-----END PUBLIC KEY-----\n"
# Opción B: ruta a clave pública
JWT_PUBLIC_KEY_PATH=/path/to/keys/jwt_public.pem

# MinIO Storage Configuration
# INTERNAL ACCESS (Docker network only)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET_PREFIX=documentos-empresa

# EXTERNAL ACCESS (through nginx proxy)
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_INTERNAL_BASE_URL=http://minio:9000

# =================================
# FLOWISE IA INTEGRATION
# =================================
# Flowise es un servicio opcional de IA para clasificación automática de documentos.
# Se configura dinámicamente desde el frontend en /configuracion/flowise

# Conexión al servidor Flowise (usado por microservicio Documentos)
# Desarrollo: http://localhost:3000/api/v1/extract
# Staging:    http://flowise-staging:3005/api/v1/extract
# Producción: http://flowise:3005/api/v1/extract
FLOWISE_ENDPOINT=http://localhost:3000/api/v1/extract
FLOWISE_API_KEY=
FLOWISE_FLOW_ID=

# Configuración del contenedor Flowise (si usas docker-compose)
# Puerto del servicio Flowise
FLOWISE_PORT=3000

# Autenticación de la UI de Flowise (OBLIGATORIO en producción)
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=change-me-in-production

# Secret key para encriptación interna de Flowise
FLOWISE_SECRET_KEY=change-me-flowise-secret-2025

# Límites de carga (ajustar según necesidad)
FLOWISE_MAX_REQUEST_SIZE=50mb
FLOWISE_MAX_UPLOAD_SIZE=50mb

# Base de datos para Flowise (usa el mismo PostgreSQL del stack)
# El schema 'flowise' se crea automáticamente
FLOWISE_DATABASE_TYPE=postgres
FLOWISE_DATABASE_HOST=postgres
FLOWISE_DATABASE_PORT=5432
FLOWISE_DATABASE_SCHEMA=flowise
# Usuario y password se toman de DB_USER y DB_PASSWORD

# Langchain (opcional, solo si usas features avanzadas)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=
LANGCHAIN_API_KEY=

# CORS para Flowise (separado por comas)
FLOWISE_CORS_ORIGINS=*

## Eliminado: MICROSERVICIO CALIDAD (QMS)

DEFAULT_TENANT_ID=1
AUTH_PUBLIC_KEY=
AUTH_JWKS_URL=

# Cerbos (optional)
CERBOS_URL=

# Firma electrónica (PKCS#12)
SIGNING_P12_PATH=
SIGNING_P12_PASS=

# Notificaciones
NOTIFY_EMAILS=
NOTIFY_WEBHOOK_URL=

# JWT RS256 (backend)
JWT_PRIVATE_KEY_PATH=/path/to/keys/jwt_private.pem

# WebSocket Documentos (seleccionar uno)
VITE_DOCUMENTOS_WS_URL=http://localhost:4802
# VITE_DOCUMENTOS_WS_URL=ws://localhost:4802

PDF_RASTERIZE_ENABLED=true
PDF_RASTERIZE_DPI=300
PDF_RASTERIZE_CHUNK_SIZE=2
PDF_RASTERIZE_MAX_RETRY=2
PDF_RASTERIZE_MAX_CONCURRENCY=2
PDF_RASTERIZE_TIMEOUT_MS=90000
PDF_RASTERIZE_BATCH_SIZE=5
PDF_RASTERIZE_FORMAT=jpeg
PDF_RASTERIZE_JPEG_QUALITY=75
PDF_RASTERIZE_SCALE_TO=1600
PDF_RASTERIZE_MAX_PAGES=2
PDF_RASTERIZE_MAX_SIZE=10485760

DOCS_MAX_DEPRECATED_VERSIONS=3
DOCS_DUE_SOON_DAYS=30
DOCS_MAX_FILES_PER_UPLOAD=20
DOCS_MAX_SIZE_PER_UPLOAD=10485760
DOCS_MAX_SIZE_PER_FILE=10485760
DOCS_MAX_SIZE_PER_FILE_BASE64=10485760
DOCS_MAX_SIZE_PER_FILE_CAMERA=10485760
DOCS_MAX_SIZE_PER_FILE_BASE64_CAMERA=10485760
DOCS_MAX_SIZE_PER_FILE_CAMERA_BASE64=10485760
DOCS_MAX_SIZE_PER_FILE_CAMERA_BASE64_CAMERA=10485760


